{
  "name": "n8n-nodes-tacticalrmm",
  "version": "1.3.6",
  "description": "An n8n node to connect to the Tactical RMM API",
  "keywords": [
    "n8n-community-node-package",
    "tacticalrmm"
  ],
  "license": "MIT",
  "homepage": "https://github.com/redanthrax/tacticalrmm-node#readme",
  "author": {
    "name": "redanthrax",
    "email": "red@4c.gg"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/redanthrax/tacticalrmm-node"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=22.22.3",
    "pnpm": ">=11.14.0"
  },
  "volta": {
    "node": "22.22.3",
    "pnpm": "11.14.0"
  },
  "main": "index.js",
  "scripts": {
    "audit:supply-chain": "node scripts/check-supply-chain.mjs",
    "build": "pnpm exec rimraf dist && pnpm exec tsc && pnpm exec gulp build:icons",
    "dev": "pnpm exec tsc --watch",
    "format": "pnpm exec prettier nodes credentials --write",
    "generate": "python3 scripts/generate-api-catalog.py",
    "lint": "pnpm exec eslint nodes credentials package.json",
    "lintfix": "pnpm exec eslint nodes credentials package.json --fix",
    "prepublishOnly": "pnpm run audit:supply-chain && pnpm run build && pnpm exec eslint -c eslint.config.prepublish.mjs nodes credentials package.json"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/TacticalRMMApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/TacticalRMM/TacticalRmm.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/eslint-plugin-community-nodes": "0.23.0",
    "@types/node": "26.1.1",
    "@typescript-eslint/parser": "8.60.1",
    "eslint": "10.7.0",
    "gulp": "5.0.1",
    "n8n-workflow": "2.30.1",
    "prettier": "3.9.5",
    "rimraf": "6.1.3",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
